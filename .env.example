# LUNR website — analytics environment variables
#
# These are read at BUILD time by scripts/build.mjs and injected into the
# generated /analytics-config.js. Locally, copy this file to `.env` and fill in
# the values. In production, set them in the Vercel project (Settings →
# Environment Variables) for the Production (and Preview) environments.
#
# Leaving a value blank disables that tool entirely — no script is loaded and
# no errors are produced.
#
# NOTE: The NEXT_PUBLIC_ prefix is a naming convention only; this is a static
# site, not Next.js. These values are public (they ship to the browser) — they
# are tracking IDs, not secrets.

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity Project ID (e.g. abcd1234ef)
NEXT_PUBLIC_CLARITY_PROJECT_ID=
